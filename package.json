{
  "name": "99-aktau",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc -b --pretty false",
    "seo:generate": "node scripts/generate-seo.mjs",
    "seo:pages": "node scripts/generate-page-entries.mjs",
    "seo:verify": "node scripts/verify-dist-seo.mjs",
    "build": "npm run seo:generate && tsc -b && vite build && npm run seo:pages && npm run seo:verify",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1",
    "test": "npm run test:server",
    "test:server": "node --test server/*.test.mjs",
    "handover:check": "node scripts/pre-handover-check.mjs"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "framer-motion": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest"
  }
}
