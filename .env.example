# Supabase project URL; store the actual value only in protected environment settings.
SUPABASE_URL=

# Public HTTPS origin used for canonical URLs, sitemap, robots and structured data.
SITE_URL=

# Server-only Supabase service role key; never expose it through a VITE_ variable.
SUPABASE_SERVICE_ROLE_KEY=

# Strong administrator password; generate and store it in a password manager.
ADMIN_PASSWORD=

# Random session-signing secret of at least 32 characters; rotate it after handover.
ADMIN_SESSION_SECRET=
